package <%= it.goPackageName %>

import (
  "bytes"
  "testing"
)

func TestHelloCommand(t *testing.T) {
  root := NewRootCommand("test")
  var out bytes.Buffer
  root.SetOut(&out)
  root.SetArgs([]string{"hello", "--name", "<%= it.projectName %>"})

  if err := root.Execute(); err != nil {
    t.Fatal(err)
  }

  if got, want := out.String(), "Hello, <%= it.projectName %>!\n"; got != want {
    t.Fatalf("output = %q, want %q", got, want)
  }
}
